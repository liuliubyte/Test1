// ==UserScript==
// @name         Question extraction
// @namespace    http://tampermonkey.net/
// @version      2026-06-28
// @description  try to take over the world!
// @author       You
// @match        https://*/*
// @icon         data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    // Your code here...
   let btn = document.createElement('button');
    btn.innerHTML = '🚀 穿透抓取所有题目';
    btn.style.cssText = 'position:fixed; top:100px; left:20px; z-index:999999; padding:10px 20px; background:#FF5722; color:white; border:none; border-radius:5px; cursor:pointer; box-shadow: 0 4px 6px rgba(0,0,0,0.3);';
    document.body.appendChild(btn);

    // 定义一个递归函数，专门用来对付“俄罗斯套娃”
    function findQuestionsInDocument(doc, className, resultList) {
        if (!doc) return;

        // 1. 把当前这层能看到的题目都装进数组
        doc.querySelectorAll(className).forEach(el => resultList.push(el));

        // 2. 找到当前层所有的 iframe，准备钻进去
        let iframes = doc.querySelectorAll('iframe');
        for (let i = 0; i < iframes.length; i++) {
            try {
                // 尝试获取 iframe 内部的网页数据
                let innerDoc = iframes[i].contentDocument || iframes[i].contentWindow.document;
                // 递归调用自己，继续往里找
                findQuestionsInDocument(innerDoc, className, resultList);
            } catch (e) {
                // 如果遇到跨域保护的 iframe 进不去，就忽略它
                console.log("跳过了一个加密的 iframe 子窗口");
            }
        }
    }

    btn.onclick = function() {
        let questionClassName = ".questionLi";//需要在网页检查第一题中获得
        let allQuestionElements = [];

        // 从最外层的顶层文档开始搜索
        findQuestionsInDocument(document, questionClassName, allQuestionElements);

        if (allQuestionElements.length === 0) {
            alert("还是没找到！检查一下是不是网页还没加载完？");
            return;
        }

        let allQuestionsText = "";

        for (let i = 0; i < allQuestionElements.length; i++) {
            // 这里用 textContent 替代 innerText，有时能抓到更多隐藏格式的内容
            let singleQuestion = allQuestionElements[i].textContent.replace(/\s+/g, ' ').trim();
            allQuestionsText += "【第 " + (i + 1) + " 题】: " + singleQuestion + "\n\n";
        }

        console.log("----- 抓取到的完整题目 -----");
        console.log(allQuestionsText);

        alert("大丰收！成功穿透抓取了 " + allQuestionElements.length + " 道题！\n请按 F12 打开控制台查看。");
    };
})();
